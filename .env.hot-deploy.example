# 热发布配置示例
# 复制为 .env.hot-deploy.local 后填写

DEPLOY_HOST=your-server-ip
DEPLOY_PORT=22
DEPLOY_USER=root
DEPLOY_PASSWORD=
DEPLOY_REMOTE_DIR=/opt/postgrad-contact-manager
DEPLOY_CONTAINER_NAME=postgrad-contact-manager
DEPLOY_PROXY_CONTAINER_NAME=postgrad-contact-manager-caddy
DEPLOY_HEALTH_URL=https://example.com/api/health
DEPLOY_WAIT_SECONDS=8
