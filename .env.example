# 数据库配置（开发环境建议 file:./dev.db）
DATABASE_URL="file:./dev.db"

# JWT 密钥（生产环境请改为安全随机字符串）
JWT_SECRET="your-secret-key-change-in-production"

# JWT 过期时间（示例：7d、12h）
JWT_EXPIRES_IN="7d"

# 服务端口
PORT=3000

# 域名配置（部署时改为你的真实域名）
DOMAIN="example.com"

# 前端应用地址（开发环境通常为 Vite 地址，生产环境填主域名）
APP_BASE_URL="http://localhost:5173"

# 服务端对外访问地址（用于 GitHub OAuth 回调）
SERVER_PUBLIC_URL="http://localhost:3000"

# HTTPS 证书通知邮箱（部署时建议填写真实邮箱）
ACME_EMAIL="your-email@example.com"

# CORS 允许来源（可写多个，逗号分隔）
CORS_ORIGIN="https://example.com,https://www.example.com,http://localhost:5173"

# 邮箱验证码配置
REGISTER_CODE_EXPIRES_MINUTES=10
REGISTER_CODE_RESEND_COOLDOWN_SECONDS=60
RESET_PASSWORD_CODE_EXPIRES_MINUTES=10
RESET_PASSWORD_CODE_RESEND_COOLDOWN_SECONDS=60

# SMTP 发信配置（正式环境务必填写）
SMTP_HOST="smtp.qq.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
SMTP_FROM_NAME="套磁管理系统"

# GitHub OAuth 配置
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_REDIRECT_URI="http://localhost:3000/api/auth/github/callback"
OAUTH_STATE_EXPIRES_IN="10m"

# 论坛管理员邮箱（多个邮箱用英文逗号分隔）
FORUM_ADMIN_EMAILS=""

# 反向代理层数（部署在 Caddy/Nginx 后建议为 1）
TRUST_PROXY=1

# 容器启动时自动执行生产迁移
AUTO_MIGRATE=true

# Node 环境
NODE_ENV=development

# 资料链接自动巡检（每日本地时间）
RESOURCE_HEALTH_SCHEDULER_ENABLED=true
RESOURCE_HEALTH_SCHEDULE_HOUR=3
RESOURCE_HEALTH_SCHEDULE_MINUTE=0
RESOURCE_HEALTH_MAX_CHECK_PER_USER=200
RESOURCE_HEALTH_TIMEOUT_MS=8000
