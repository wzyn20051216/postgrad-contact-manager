generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String
  nickname       String?
  avatar         String?
  emailVerified  Boolean  @default(true)
  githubId       String?  @unique
  githubUsername String?
  tokenVersion   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  professors        Professor[]
  tags              Tag[]
  emailTemplates    EmailTemplate[]
  reminders         Reminder[]
  notes             Note[]
  resourceLinks     ResourceLink[]
  healthReports     ResourceHealthReport[]
  forumPosts        ForumPost[]
  forumComments     ForumComment[]
  forumPostLikes    ForumPostLike[]
  forumNotificationsReceived ForumNotification[] @relation("ForumNotificationRecipient")
  forumNotificationsSent     ForumNotification[] @relation("ForumNotificationActor")
}

model EmailVerificationCode {
  id         String   @id @default(cuid())
  email      String
  purpose    String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([email, purpose, createdAt])
}

model Professor {
  id                String   @id @default(cuid())
  userId            String
  name              String
  university        String
  college           String
  title             String   @default("PROFESSOR")
  researchArea      String
  email             String?
  phone             String?
  homepage          String?
  wechat            String?
  schoolRating      String?  @default("B")
  reputationScore   Int?     @default(0)
  reputationComment String?
  contactStatus     String   @default("NOT_CONTACTED")
  priority          Int      @default(0)
  source            String?
  enrollmentQuota   Int?
  acceptingStudents Boolean  @default(true)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user           User              @relation(fields: [userId], references: [id])
  interviews     Interview[]
  tags           TagOnProfessor[]
  reminders      Reminder[]
  noteItems      Note[]
  statusLogs     StatusLog[]
  communications Communication[]
}

model Interview {
  id               String   @id @default(cuid())
  professorId      String
  scheduledAt      DateTime
  duration         Int?     @default(30)
  method           String   @default("ONLINE")
  location         String?
  meetingLink      String?
  status           String   @default("SCHEDULED")
  preparationNotes String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  professor Professor      @relation(fields: [professorId], references: [id], onDelete: Cascade)
  logs      InterviewLog[]
}

model InterviewLog {
  id             String   @id @default(cuid())
  interviewId    String
  content        String
  selfRating     Int?
  mood           String?
  questionsAsked String?
  keyTakeaways   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
}

model Tag {
  id     String @id @default(cuid())
  userId String
  name   String
  color  String @default("#4F8EF7")

  user       User             @relation(fields: [userId], references: [id])
  professors TagOnProfessor[]
}

model TagOnProfessor {
  professorId String
  tagId       String

  professor Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([professorId, tagId])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  subject   String
  content   String
  category  String   @default("FIRST_CONTACT")
  isPreset  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Reminder {
  id          String   @id @default(cuid())
  userId      String
  professorId String?
  title       String
  description String?
  remindAt    DateTime
  type        String   @default("FOLLOW_UP")
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id])
  professor Professor? @relation(fields: [professorId], references: [id], onDelete: SetNull)
}

model Note {
  id          String   @id @default(cuid())
  userId      String
  professorId String?
  title       String
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id])
  professor Professor? @relation(fields: [professorId], references: [id], onDelete: SetNull)
}

model ResourceLink {
  id          String   @id @default(cuid())
  userId      String
  title       String
  url         String
  category    String   @default("未分类")
  isPinned    Boolean  @default(false)
  visitCount  Int      @default(0)
  lastVisitedAt DateTime?
  healthStatus String   @default("UNKNOWN")
  lastCheckedAt DateTime?
  lastCheckStatusCode Int?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model ResourceHealthReport {
  id               String   @id @default(cuid())
  userId           String
  triggerType      String   @default("SCHEDULED")
  totalCount       Int      @default(0)
  checkedCount     Int      @default(0)
  availableCount   Int      @default(0)
  unavailableCount Int      @default(0)
  unknownCount     Int      @default(0)
  skippedCount     Int      @default(0)
  startedAt        DateTime @default(now())
  finishedAt       DateTime?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model SchoolOfficialSource {
  id          String   @id @default(cuid())
  schoolName  String
  siteName    String
  baseUrl     String   @unique
  domain      String
  description String?
  priority    Int      @default(100)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolName, isActive, priority])
  @@index([domain, isActive])
}

model ForumCategory {
  id          String      @id @default(cuid())
  name        String      @unique
  description String?
  sortOrder   Int         @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  posts ForumPost[]

  @@index([sortOrder, createdAt])
}

model ForumPost {
  id           String   @id @default(cuid())
  categoryId   String?
  userId       String
  title        String
  content      String
  isPinned     Boolean  @default(false)
  viewCount    Int      @default(0)
  commentCount Int      @default(0)
  likeCount    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category ForumCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments ForumComment[]
  likes    ForumPostLike[]
  notifications ForumNotification[]

  @@index([categoryId, createdAt])
  @@index([userId, createdAt])
  @@index([isPinned, updatedAt])
}

model ForumComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  parentId  String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post     ForumPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   ForumComment?  @relation("ForumCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  ForumComment[] @relation("ForumCommentReplies")
  notifications ForumNotification[]

  @@index([postId, createdAt])
  @@index([userId, createdAt])
  @@index([parentId, createdAt])
}

model ForumPostLike {
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId, createdAt])
}

model ForumNotification {
  id              String   @id @default(cuid())
  recipientUserId String
  actorUserId     String?
  postId          String?
  commentId       String?
  type            String
  content         String
  isRead          Boolean  @default(false)
  createdAt       DateTime @default(now())
  readAt          DateTime?

  recipientUser User         @relation("ForumNotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  actorUser     User?        @relation("ForumNotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  post          ForumPost?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment       ForumComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([recipientUserId, isRead, createdAt])
  @@index([recipientUserId, createdAt])
  @@index([type, createdAt])
}

model StatusLog {
  id          String   @id @default(cuid())
  professorId String
  fromStatus  String
  toStatus    String
  remark      String?
  createdAt   DateTime @default(now())

  professor Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)
}

model Communication {
  id           String    @id @default(cuid())
  professorId  String
  type         String    @default("EMAIL")
  subject      String?
  content      String?
  sentAt       DateTime  @default(now())
  isReplied    Boolean   @default(false)
  repliedAt    DateTime?
  replyContent String?

  professor Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)
}
